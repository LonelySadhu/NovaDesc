# ─────────────────────────────────────────────────────────────
#  NovaDesc — environment template
#  Copy to .env and fill in real values before starting.
#  Never commit .env to git.
# ─────────────────────────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=novadesc
POSTGRES_PASSWORD=change-me
POSTGRES_DB=novadesc

# Backend
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
FRONTEND_PORT=80

# AI provider: ollama (local/air-gapped) or anthropic (cloud)
AI_PROVIDER=ollama
OLLAMA_MODEL=llama3
ANTHROPIC_API_KEY=

# Embeddings: ollama (nomic-embed-text) or openai (text-embedding-3-small)
EMBEDDING_PROVIDER=ollama
OPENAI_API_KEY=

# MinIO (file storage)
MINIO_ROOT_USER=novadesc
MINIO_ROOT_PASSWORD=change-me
MINIO_BUCKET_MEDIA=novadesc-media
MINIO_BUCKET_DOCS=novadesc-docs

# Email notifications (leave SMTP_HOST empty to disable)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@novadesc.local
SMTP_TLS=true

# Initial admin user (used by: make seed)
ADMIN_USER=admin
ADMIN_PASS=change-me

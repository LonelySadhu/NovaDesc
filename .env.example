# ─────────────────────────────────────────
#  NovaDesc — Environment Configuration
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=novadesc
POSTGRES_PASSWORD=change_me
POSTGRES_DB=novadesc

# App
SECRET_KEY=change_me_to_random_64_char_string
FRONTEND_PORT=80

# AI Provider: "ollama" (local) | "anthropic" (cloud)
AI_PROVIDER=ollama
OLLAMA_MODEL=llama3

# Required only when AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Initial admin user (used on first startup)
ADMIN_USER=admin
ADMIN_PASS=change_me
